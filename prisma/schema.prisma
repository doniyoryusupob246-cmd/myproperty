model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?
  filterId  Int?
  listingId Int?
  sentAt    DateTime @default(now())
  filter    Filter?  @relation(fields: [filterId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
}

